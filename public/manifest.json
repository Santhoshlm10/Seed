{
    "name": "Seed",
    "description": "Open-source, fully offline data generation tool for developers to create and export mock data securely.",
    "version": "0.0.1",
    "manifest_version": 3,
    "minimum_chrome_version": "114",
    "icons": {
        "16": "logo16.png",
        "48": "logo48.png",
        "128": "logo128.png"
    },
    "action": {
        "default_title": "Open Seed",
        "default_icon": {
            "16": "logo16.png",
            "48": "logo48.png",
            "128": "logo128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "storage",
        "tabs",
        "sidePanel",
        "downloads",
        "scripting",
        "activeTab"
    ],
    "host_permissions": ["<all_urls>"],
    "side_panel": {
        "default_path": "index.html"
    },
    "homepage_url": "https://github.com/Santhoshlm10/seed"
}