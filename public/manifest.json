{
    "name": "Seed",
    "description": "Seed is a developer tool that helps you work with test data. Define a schema, generate realistic fake records, export them to CSV, JSON, Excel or SQL — or inject them directly into any web form to speed up your testing workflow.",
    "version": "0.0.1",
    "manifest_version": 3,
    "minimum_chrome_version": "114",
    "icons": {
        "16": "logo16.png",
        "48": "logo48.png",
        "128": "logo128.png"
    },
    "action": {
        "default_title": "Open Seed",
        "default_icon": {
            "16": "logo16.png",
            "48": "logo48.png",
            "128": "logo128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "storage",
        "tabs",
        "sidePanel",
        "downloads",
        "scripting",
        "activeTab"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "side_panel": {
        "default_path": "index.html"
    },
    "homepage_url": "https://github.com/Santhoshlm10/seed"
}