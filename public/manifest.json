{
    "name": "Seed",
    "description": "Open-source, fully offline data generation tool for developers to create and export mock data securely.",
    "version": "0.0.1",
    "manifest_version": 3,
    "icons": {
        "16": "logo16.png",
        "48": "logo48.png",
        "128": "logo128.png"
    },
    "minimum_chrome_version": "90",
    "permissions": [
        "storage",
        "tabs",
        "sidePanel",
        "downloads",
        "scripting",
        "activeTab"
    ],
    "side_panel": {
        "default_path": "index.html"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],
    "host_permissions": ["<all_urls>"],
    "homepage_url": "https://github.com/Santhoshlm10/seed"
}